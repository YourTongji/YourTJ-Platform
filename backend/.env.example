PORT=8080
# Shared-host deployments set 127.0.0.1; container platforms normally keep 0.0.0.0.
BIND_ADDRESS=0.0.0.0
RUST_LOG=info,api=debug,tower_http=debug

# PolarDB (PostgreSQL-compatible). Use the primary for writes.
DATABASE_URL=postgres://yourtj:yourtj@localhost:5432/yourtj
# Optional read replica for read-heavy paths (falls back to DATABASE_URL when unset).
DATABASE_REPLICA_URL=

REDIS_URL=redis://localhost:6379
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=dev-master-key

# JWT signing secret (change for production).
JWT_SECRET=dev-only-change-me
JWT_TTL=900
REFRESH_TTL=604800
# Exact comma-separated browser origins; wildcards, paths, credentials, query, and fragments fail startup.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://pf-dev.yourtj.de

# System Ed25519 private key seed (hex-encoded, 64 hex chars = 32 bytes) for signing
# mint/escrow ledger entries. Generate one with:  openssl rand -hex 32
# Then compute the public key at startup; the key is used to sign system-originated
# ledger entries (mint, escrow_hold, escrow_release).
# WARNING: If this key is missing or invalid, the server will refuse to start.
# This deterministic seed is for local development only. Production must inject
# a separately generated secret from the deployment secret store.
CREDIT_SYSTEM_PRIVATE_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Alibaba Cloud OSS direct upload. Leave empty to fail media upload routes closed.
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ROLE_ARN=
OSS_CALLBACK_BASE_URL=

# Private sanitized Delivery storage. These credentials must be a different least-privilege RAM
# principal from the Ingest STS issuer above. The CDN purge principal is independent again.
MEDIA_DELIVERY_OSS_BUCKET=
MEDIA_DELIVERY_OSS_ACCESS_KEY_ID=
MEDIA_DELIVERY_OSS_ACCESS_KEY_SECRET=
MEDIA_CDN_BASE_URL=https://media-dev.yourtj.de
MEDIA_CDN_PRIMARY_KEY=
MEDIA_CDN_SECONDARY_KEY=
MEDIA_CDN_SIGNING_KEY_SLOT=primary
MEDIA_CDN_URL_TTL_SECONDS=300
CDN_ACCESS_KEY_ID=
CDN_ACCESS_KEY_SECRET=
# Enable only after migration 0057, all writers are on the binding-aware image, and reconciliation
# reports zero missing profile/promotion/draft bindings.
MEDIA_RETENTION_GC_ENABLED=false
# Enable only after the privacy owner ratifies the exact-purpose/evidence retention schedule.
MEDIA_OPERATIONS_HISTORY_PURGE_ENABLED=false

# Email-at-rest encryption (AES-256-GCM + HMAC-SHA256 blind index). Local synthetic
# development may leave keys empty; main staging/production deployment refuses plaintext.
# Generate distinct keys with:
#   openssl rand -hex 32  # for AEAD
#   openssl rand -hex 32  # for blind index
# Main staging/production requires EMAIL_ENCRYPTION_STRICT=true.
EMAIL_ENCRYPTION_ACTIVE_VERSION=1
EMAIL_ENCRYPTION_ACTIVE_AEAD=
EMAIL_ENCRYPTION_ACTIVE_BLIND=
EMAIL_ENCRYPTION_STRICT=false

# Outbound email. `log` is a redacted local/test sink and does not deliver mail.
# Production uses `cloudflare`; keep its API token in the deployment secret store only.
EMAIL_PROVIDER=log
EMAIL_FROM=welcome@yourtj.de
CLOUDFLARE_EMAIL_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
CLOUDFLARE_EMAIL_API_BASE_URL=https://api.cloudflare.com/client/v4

# Legacy SMTP fallback. Set EMAIL_PROVIDER=smtp and configure these values to use it.
# SMTP_FROM remains accepted as a backward-compatible alias for EMAIL_FROM.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# TongjiCaptcha (YourTongji/YourTJCaptcha) siteverify endpoint. The application uses
# this public endpoint by default; set an empty value only to fail protected writes closed.
CAPTCHA_SITEVERIFY_URL=https://captcha.07211024.xyz/api/siteverify
