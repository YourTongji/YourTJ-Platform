PORT=8080
RUST_LOG=info,api=debug,tower_http=debug

# PolarDB (PostgreSQL-compatible). Use the primary for writes.
DATABASE_URL=postgres://yourtj:yourtj@localhost:5432/yourtj
# Optional read replica for read-heavy paths (falls back to DATABASE_URL when unset).
DATABASE_REPLICA_URL=

REDIS_URL=redis://localhost:6379
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=

# JWT signing secret (change for production).
JWT_SECRET=dev-only-change-me
JWT_TTL=900
REFRESH_TTL=604800

# System Ed25519 key (base64) for signing mint ledger entries.
CREDIT_SYSTEM_PRIVATE_KEY=
